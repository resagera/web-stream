# Copy to .env for local or production overrides.
#
# For a real event, change every change-me/dev secret.

APP_DOMAIN=stream.example.com
LIVEKIT_DOMAIN=livekit.example.com
ACME_EMAIL=you@example.com
PUBLIC_ORIGIN=http://localhost:8080
SECURE_COOKIES=false
MAX_PHOTO_URL_BYTES=350000

GUEST_PASSWORD=change-me
BROADCASTER_PASSWORD=change-me-broadcaster
ADMIN_PASSWORD=change-me-admin
BACKEND_PORT=8080
DATA_HOST_DIR=./server/data

LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=family-event

# Optional LiveKit built-in TURN fallback for restrictive networks.
# Keep disabled for local dev. For production use a dedicated DNS name,
# for example turn.example.com, pointing to the same server.
LIVEKIT_TURN_ENABLED=false
TURN_DOMAIN=turn.example.com
LIVEKIT_TURN_UDP_PORT=3478
LIVEKIT_TURN_TLS_PORT=5349
LIVEKIT_TURN_RELAY_RANGE_START=50101
LIVEKIT_TURN_RELAY_RANGE_END=50200
LIVEKIT_TURN_EXTERNAL_TLS=false
LIVEKIT_TURN_CERT_FILE=
LIVEKIT_TURN_KEY_FILE=
